---
import MoonIcon from "@/components/icons/MoonIcon.astro";
import SunIcon from "@/components/icons/SunIcon.astro";
---

<button
  id="theme-toggle"
  class="p-2 text-text-light dark:text-text-dark rounded-full hover:bg-gray-200 dark:hover:bg-gray-800 transition-colors"
  aria-label="Toggle theme"
>
  <span id="theme-icon" class="block w-5 h-5">
    <SunIcon id="sun-icon" class="" />
    <MoonIcon id="moon-icon" class="hidden" />
  </span>
</button>

<script>
  function applyTheme(theme: "dark" | "light") {
    const htmlElement = document.documentElement;
    const sunIcon = document.getElementById("sun-icon");
    const moonIcon = document.getElementById("moon-icon");

    if (theme === "dark") {
      htmlElement.classList.add("dark");
      htmlElement.setAttribute("data-theme", "dark");
      localStorage.setItem("theme", "dark");
      sunIcon?.classList.add("hidden");
      moonIcon?.classList.remove("hidden");
    } else {
      htmlElement.classList.remove("dark");
      htmlElement.setAttribute("data-theme", "light");
      localStorage.setItem("theme", "light");
      sunIcon?.classList.remove("hidden");
      moonIcon?.classList.add("hidden");
    }
  }

  function toggleTheme() {
    const htmlElement = document.documentElement;
    const isDark = htmlElement.classList.contains("dark");
    applyTheme(isDark ? "light" : "dark");
  }

  function initTheme() {
    const savedTheme = localStorage.getItem("theme");
    const prefersDark = window.matchMedia(
      "(prefers-color-scheme: dark)",
    ).matches;
    const initial =
      savedTheme === "dark" || savedTheme === "light"
        ? savedTheme
        : prefersDark
          ? "dark"
          : "light";
    applyTheme(initial as "dark" | "light");
  }

  document
    .getElementById("theme-toggle")
    ?.addEventListener("click", toggleTheme);
  initTheme();
</script>
