---
import { skills } from "@/data/skills";
import { Tab, TabItem } from "free-astro-components";
---

<section
  class="max-w-screen-lg mx-auto md:py-20 md:mt-10 py-10 md:min-h-[90vh] mx:px-0 px-4"
  id="sobre"
>
  <div class="flex gap-10 md:flex-row flex-col">
    <!-- Foto  -->
    <div class="md:min-w-[25vw] w-full">
      <div class="rounded-md">
        <img
          src="/foto-vinicius.webp"
          alt="Foto de Vinícius Reis, Desenvolvedor Front-end"
          class="object-fill w-full h-auto rounded-md"
        />
      </div>
    </div>

    <!-- Tabs sobre mim -->
    <div class="w-full">
      <Tab
        tabs={[
          { label: "Sobre mim", active: true },
          { label: "Minhas habilidades" },
        ]}
        ><TabItem active
          ><h2 class="md:text-2xl text-xl font-medium md:mb-4 mb-5">
            Desenvolvedor Front-end e apaixonado por tecnologia
          </h2><p class="md:text-lg text-base">
            Sou desenvolvedor Full Stack com experiência na criação de
            interfaces modernas, responsivas e otimizadas, além do
            desenvolvimento de APIs e integrações completas. Trabalho com
            tecnologias como React, Next.js, Astro, Node.js e Tailwind CSS, e
            também possuo domínio em WordPress com Elementor. Com uma base
            sólida em UI/UX design, uno criatividade, performance e foco em
            resultados para entregar soluções digitais de alta qualidade.
            Atualmente, atuo como freelancer em Paragominas/PA, desenvolvendo
            Landing Pages, E-commerces, Blogs e Dashboards personalizados.
          </p></TabItem
        ><TabItem
          ><h2 class="mb-4 md:text-2xl text-xl font-medium">
            Especializado nas principais tecnologias disponíveis no mercado.
          </h2>
          <div class="flex flex-wrap items-center gap-3">
            {
              skills.map((skill) => (
                <div class="border rounded-xl p-4 dark:border-zinc-800 border-zinc-300 flex flex-col items-center gap-2">
                  <skill.icon size={28} />
                  <span class="text-sm">{skill.name}</span>
                </div>
              ))
            }
          </div>
        </TabItem></Tab
      >
    </div>
  </div>
</section>
