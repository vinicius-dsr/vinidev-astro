---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/ui/Button.astro";
import { QRCodePIX } from "@/components/QRCodePIX";
import { links } from "@/data/socialLinks";
import { ArrowLeft } from "lucide-react";
import { FaWhatsapp } from "react-icons/fa";
const whatsapp =
  links.find((l) => l.name.toLowerCase() === "whatsapp")?.href ??
  "https://wa.me/5591992761377";
---

<Layout title="Buy Me a Coffee | Vinícius Reis">
  <main class="min-h-screen">
    <div
      class="max-w-screen-lg mx-auto md:py-24 py-10 md:mt-10 md:mb-10 mx:px-0 px-4"
    >
      <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-12">
          <span
            class="md:text-xl text-base font-semibold uppercase dark:text-primary-dark text-primary-light"
            >Contribuições</span
          >
          <h2 class="md:text-5xl text-3xl mt-2 mb-4">Buy Me a Coffee</h2>
          <p class="md:text-xl text-base text-center max-w-screen-md mx-auto">
            Gostou do meu trabalho? Que tal me pagar um café? Sua contribuição
            me ajuda a continuar criando conteúdo e desenvolvendo projetos.
          </p>
        </div>

        <!-- Main Content -->
        <div class="grid md:grid-cols-2 gap-8 items-start">
          <!-- Left Column - Info -->
          <div
            class="bg-secondary-light dark:bg-background-dark border border-zinc-300 dark:border-zinc-800 rounded-xl p-8"
          >
            <h2 class="md:text-2xl text-xl font-medium mb-6">
              💝 Por que contribuir?
            </h2>

            <div class="space-y-4 mb-8">
              <div class="flex items-start space-x-3">
                <div
                  class="w-6 h-6 bg-primary-dark dark:bg-primary-light rounded-full flex items-center justify-center flex-shrink-0 mt-1"
                >
                  <svg
                    class="w-3 h-3 text-white dark:text-black"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"></path>
                  </svg>
                </div>
                <p>Apoie o desenvolvimento de projetos open source</p>
              </div>

              <div class="flex items-start space-x-3">
                <div
                  class="w-6 h-6 bg-primary-dark dark:bg-primary-light rounded-full flex items-center justify-center flex-shrink-0 mt-1"
                >
                  <svg
                    class="w-3 h-3 text-white dark:text-black"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"></path>
                  </svg>
                </div>
                <p>Incentive a criação de mais conteúdo técnico</p>
              </div>

              <div class="flex items-start space-x-3">
                <div
                  class="w-6 h-6 bg-primary-dark dark:bg-primary-light rounded-full flex items-center justify-center flex-shrink-0 mt-1"
                >
                  <svg
                    class="w-3 h-3 text-white dark:text-black"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"></path>
                  </svg>
                </div>
                <p>Ajude a manter os serviços e ferramentas gratuitos</p>
              </div>
            </div>

            <!-- Suggested Amounts -->
            <div class="mb-6">
              <h3 class="text-lg font-semibold mb-4">Valores sugeridos:</h3>
              <div class="grid grid-cols-2 gap-3">
                <div
                  class="bg-secondary-light dark:bg-background-dark border border-zinc-300 dark:border-zinc-800 rounded-lg p-3 text-center"
                >
                  <div class="text-2xl mb-1">☕</div>
                  <div class="text-sm font-medium">R$ 5,00</div>
                  <div class="text-xs text-zinc-600 dark:text-zinc-400">
                    Um café
                  </div>
                </div>
                <div
                  class="bg-secondary-light dark:bg-background-dark border border-zinc-300 dark:border-zinc-800 rounded-lg p-3 text-center"
                >
                  <div class="text-2xl mb-1">🥪</div>
                  <div class="text-sm font-medium">R$ 15,00</div>
                  <div class="text-xs text-zinc-600 dark:text-zinc-400">
                    Lanche
                  </div>
                </div>
                <div
                  class="bg-secondary-light dark:bg-background-dark border border-zinc-300 dark:border-zinc-800 rounded-lg p-3 text-center"
                >
                  <div class="text-2xl mb-1">🍕</div>
                  <div class="text-sm font-medium">R$ 30,00</div>
                  <div class="text-xs text-zinc-600 dark:text-zinc-400">
                    Pizza
                  </div>
                </div>
                <div
                  class="bg-secondary-light dark:bg-background-dark border border-zinc-300 dark:border-zinc-800 rounded-lg p-3 text-center"
                >
                  <div class="text-2xl mb-1">❤️</div>
                  <div class="text-sm font-medium">Qualquer valor</div>
                  <div class="text-xs text-zinc-600 dark:text-zinc-400">
                    Sua escolha
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Right Column - QR Code -->
          <div
            class="bg-secondary-light dark:bg-background-dark border border-zinc-300 dark:border-zinc-800 rounded-xl p-8"
          >
            <h2 class="md:text-2xl text-xl font-medium mb-6 text-center">
              Pague via PIX
            </h2>

            <QRCodePIX client:only="react" />

            <div
              class="mt-6 p-4 bg-secondary-light dark:bg-background-dark border border-zinc-300 dark:border-zinc-800 rounded-lg"
            >
              <div class="flex items-start space-x-3">
                <svg
                  class="w-5 h-5 text-primary-dark dark:text-primary-light flex-shrink-0 mt-0.5"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                    clip-rule="evenodd"></path>
                </svg>
                <div>
                  <p class="text-sm font-medium">Como funciona:</p>
                  <p class="text-sm text-zinc-700 dark:text-zinc-300 mt-1">
                    1. Abra o app do seu banco<br />
                    2. Escaneie o QR Code acima<br />
                    3. Confirme o pagamento<br />
                    4. Pronto! Muito obrigado!
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Thank You Message -->
        <div class="mt-12 text-center">
          <div
            class="bg-secondary-light dark:bg-background-dark border border-zinc-300 dark:border-zinc-800 rounded-xl p-8 max-w-2xl mx-auto"
          >
            <h3 class="md:text-2xl text-xl font-medium mb-4">
              Muito obrigado!
            </h3>
            <p class="mb-6">
              Cada contribuição, por menor que seja, faz uma grande diferença.
              Sua generosidade me motiva a continuar compartilhando conhecimento
              e criando soluções incríveis!
            </p>
            <div class="md:flex row justify-center gap-4">
              <Button href="/" variant="primary" class="justify-center"
                ><ArrowLeft size={17} /> Voltar ao site
              </Button>
              <Button href={whatsapp} variant="secondary" class="justify-center"
                ><FaWhatsapp size={17} /> Falar no WhatsApp</Button
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
